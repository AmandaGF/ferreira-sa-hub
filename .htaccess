# Ferreira & Sá Hub — .htaccess de segurança

# Charset padrão
AddDefaultCharset UTF-8

# Bloquear acesso ao diretório core/
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forçar sem www
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^(.*)$ https://%1/conecta/$1 [R=301,L]

    # Bloquear acesso direto a arquivos do core
    RewriteRule ^core/ - [F,L]

    # Redirecionar raiz para dashboard
    RewriteRule ^$ modules/dashboard/ [L,R=302]
    RewriteRule ^index\.php$ modules/dashboard/ [L,R=302]
</IfModule>

# Bloquear listagem de diretórios
Options -Indexes

# Bloquear acesso a arquivos sensíveis
<FilesMatch "\.(sql|md|log|ini|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquear acesso ao config.php
<Files "config.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# Headers de segurança extras
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    # Libera microfone e câmera pro próprio domínio (usado no WhatsApp CRM pra
    # gravar áudio de voz). Mantém geolocation bloqueada.
    Header always set Permissions-Policy "camera=(self), microphone=(self), geolocation=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# Compressão gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache de assets estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>
