# ============================================================
# /conecta/cron/.htaccess
# ============================================================
#
# PROPÓSITO:
#   Bloquear acesso HTTP direto à pasta /cron/, EXCETO quando a
#   query string contém a chave de admin (?key=fsa-hub-deploy-2026).
#
# POR QUE A CHAVE?
#   Os cron jobs do cPanel chamam as URLs via curl (HTTP), não CLI.
#   Os próprios scripts já validam a chave — essa camada só
#   garante que nenhum cron sem validação interna seja acessível
#   por acidente via navegador.
#
# O QUE NÃO AFETA:
#   - Execução via CLI (cron cPanel rodando php direto)
#   - Uso via include/require de módulos (filesystem, não HTTP)
#
# HISTÓRICO:
#   22/Abril/2026 — .htaccess original bloqueava HTTP TOTAL. Isso
#   quebrou o cron de aniversários (e outros) que o cPanel chama
#   via curl. Reescrito em 23/Abril pra permitir acesso HTTP com
#   a chave correta.
# ============================================================

# --- Bloqueia acesso HTTP sem a chave correta -----------------
RewriteEngine On
RewriteCond %{QUERY_STRING} !(^|&)key=fsa-hub-deploy-2026($|&)
RewriteRule ^ - [F,L]

# --- Desabilita listagem de diretório -------------------------
Options -Indexes

# --- Logs e configs bloqueados INDEPENDENTE da chave ----------
# (não devem ser servidos via web em hipótese alguma)
<FilesMatch "\.(log|ini|conf)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
